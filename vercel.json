{
  "rewrites": [
    {
      "source": "/pay/:id",
      "destination": "/api/pay?id=:id"
    },
    {
      "source": "/((?!assets/|image/|public/|.*\\..*$).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" }
      ]
    }
  ]
}