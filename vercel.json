{
  "rewrites": [
    {
      "source": "/pay/:id",
      "destination": "/api/pay?id=:id"
    },
    {
      "source": "/certificate/:slug/:phase",
      "destination": "/api/certificate?slug=:slug&phase=:phase"
    },
    {
      "source": "/((?!assets/|image/|public/|.*\\..*$).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        }
      ]
    }
  ]
}