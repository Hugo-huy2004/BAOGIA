{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.hugowishpax.studio/api/:path*"
    },
    {
      "source": "/pay/:id",
      "destination": "https://api.hugowishpax.studio/api/pay?id=:id"
    },
    {
      "source": "/certificate/:slug/:phase",
      "destination": "https://api.hugowishpax.studio/api/bios/certificate/:slug/:phase"
    },
    {
      "source": "/((?!assets/|image/|public/|.*\\..*$).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        }
      ]
    }
  ]
}