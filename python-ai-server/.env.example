# Google Gemini API Key (primary — supports GEMINI_API_KEY, GEMINI_API_KEY_2, GEMINI_API_KEY_3... for free-tier key rotation)
# Lấy khóa tại: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Free-tier fallback providers — all optional. Each uses its own independent
# free rate-limit pool, so adding more of these raises how many concurrent
# users get a real AI reply (instead of the local fallback) once Gemini's
# quota is exhausted. Safe to leave unset — each one no-ops if its key is missing.
# Groq — https://console.groq.com/keys (very fast, generous free tier)
GROQ_API_KEY=
# Cerebras Cloud — https://cloud.cerebras.ai/ (very fast, generous free tier)
CEREBRAS_API_KEY=
# OpenRouter — https://openrouter.ai/keys (free-tagged models, e.g. deepseek/qwen/llama)
OPENROUTER_API_KEY=
