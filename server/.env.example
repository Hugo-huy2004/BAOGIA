# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/hugo_wishpax
# For MongoDB Atlas cloud:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/hugo_wishpax

# Server Port
PORT=5000

# PayOS Configuration
PAYOS_CLIENT_ID=your-payos-client-id
PAYOS_API_KEY=your-payos-api-key
PAYOS_CHECKSUM_KEY=your-payos-checksum-key

# Auth secrets — REQUIRED in production (server refuses to start without them)
JWT_SECRET=generate-with-openssl-rand-hex-32
JOY_QR_SECRET=generate-with-openssl-rand-hex-32
# Must match the frontend VITE_GOOGLE_CLIENT_ID (validates Google login audience)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Optional Python AI server provider pool
GEMINI_API_KEY=your-gemini-api-key
GEMINI_API_KEYS=
GROQ_API_KEY=
GROQ_MODELS=llama-3.3-70b-versatile,llama-3.1-8b-instant
HUGOPSY_ALLOW_FREE_AI_FALLBACK=true
AI_PROVIDER_COOLDOWN_SECONDS=90
OPENROUTER_API_KEY=
# One-time admin bootstrap (remove after first run)
# ADMIN_SEED_USERNAME=
# ADMIN_SEED_PASSWORD=
