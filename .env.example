# Frontend API Configuration
# Development
VITE_API_URL=http://localhost:5000/api
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Production (uncomment and update as needed)
# VITE_API_URL=https://your-production-api.com/api

# Internal API security
VITE_INTERNAL_API_KEY=your_secret_internal_key_here

# WebSocket
VITE_WS_URL=ws://localhost:5000/ws

# AI Server
VITE_AI_URL=http://localhost:8000

# AI provider pool (Python AI server)
# Gemini remains the primary provider. Add multiple keys with GEMINI_API_KEYS=key1,key2,key3.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_API_KEYS=
# Groq free-tier fallback, OpenAI-compatible and very fast. Free tiers still have rate limits.
GROQ_API_KEY=
GROQ_MODELS=llama-3.3-70b-versatile,llama-3.1-8b-instant
HUGOPSY_ALLOW_FREE_AI_FALLBACK=true
AI_PROVIDER_COOLDOWN_SECONDS=90
# OpenRouter is kept for non-clinical guide/classification/premium JSON fallback, not crisis chat.
OPENROUTER_API_KEY=
